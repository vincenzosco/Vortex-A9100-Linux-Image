# BusyBox configuration fragment for Vortex86 A9100
# These settings ensure essential applets are enabled

# Shell
CONFIG_ASH=y
CONFIG_ASH_BASH_COMPAT=y
CONFIG_ASH_JOB_CONTROL=y
CONFIG_ASH_READ_NCHARS=n

# Core utilities
CONFIG_CAT=y
CONFIG_CHMOD=y
CONFIG_CHOWN=y
CONFIG_CP=y
CONFIG_DATE=y
CONFIG_DD=y
CONFIG_DF=y
CONFIG_DMESG=y
CONFIG_ECHO=y
CONFIG_FIND=y
CONFIG_GREP=y
CONFIG_GUNZIP=y
CONFIG_GZIP=y
CONFIG_HOSTNAME=y
CONFIG_KILL=y
CONFIG_KILLALL=y
CONFIG_LN=y
CONFIG_LOGGER=y
CONFIG_LOGIN=y
CONFIG_LS=y
CONFIG_LSOF=y
CONFIG_MKDIR=y
CONFIG_MKFS_EXT2=y
CONFIG_MKNOD=y
CONFIG_MKSWAP=n
CONFIG_MOUNT=y
CONFIG_MV=y
CONFIG_PIDOF=y
CONFIG_PING=y
CONFIG_POWEROFF=n
CONFIG_PRINTENV=y
CONFIG_PS=y
CONFIG_PWD=y
CONFIG_REBOOT=y
CONFIG_RM=y
CONFIG_RMDIR=y
CONFIG_SED=y
CONFIG_SEQ=y
CONFIG_SLEEP=y
CONFIG_SORT=y
CONFIG_SWAPON=n
CONFIG_SWAPOFF=n
CONFIG_SYNC=y
CONFIG_SYSLOGD=y
CONFIG_KLOGD=y
CONFIG_TAR=y
CONFIG_TAIL=y
CONFIG_TEE=y
CONFIG_TEST=y
CONFIG_TIME=y
CONFIG_TOP=y
CONFIG_TOUCH=y
CONFIG_TR=y
CONFIG_TRUE=y
CONFIG_UPTIME=y
CONFIG_USLEEP=n
CONFIG_UUDECODE=n
CONFIG_UUENCODE=n
CONFIG_VI=y
CONFIG_WATCH=y
CONFIG_WC=y
CONFIG_WGET=y
CONFIG_WHICH=y
CONFIG_XARGS=y
CONFIG_ZCAT=y

# Init
CONFIG_INIT=y
CONFIG_FEATURE_INITRD=y
CONFIG_FEATURE_INIT_SCTTY=y

# Networking
CONFIG_FEATURE_IFCONFIG=y
CONFIG_IFCONFIG=y
CONFIG_IFUPDOWN=y
CONFIG_IFUPDOWN_IFSTATE_PATH="/var/run/ifstate"
CONFIG_IP=y
CONFIG_IPADDR=y
CONFIG_IPLINK=y
CONFIG_IPROUTE=y
CONFIG_NETSTAT=y
CONFIG_NSLOOKUP=y
CONFIG_NTPDATE=y
CONFIG_PING=y
CONFIG_ROUTE=y
CONFIG_TELNET=y
CONFIG_TFTP=n
CONFIG_UDHCPC=y
CONFIG_UDHCPC_DEFAULT_SCRIPT="/usr/share/udhcpc/default.script"
CONFIG_WGET=y

# Linux Module utilities
CONFIG_MODPROBE_SMALL=y
CONFIG_DEPMOD=y
CONFIG_INSMOD=y
CONFIG_LSMOD=y
CONFIG_MODPROBE=y
CONFIG_RMMOD=y

# Miscellaneous
CONFIG_HDPARM=y
CONFIG_MDEV=y
CONFIG_FEATURE_MDEV_CONF=y
CONFIG_SETSERIAL=n
CONFIG_UBIATTACH=n

# Compression
CONFIG_GZIP=y
CONFIG_GUNZIP=y
CONFIG_TAR=y
CONFIG_FEATURE_TAR_CREATE=y
CONFIG_FEATURE_TAR_FROM=y
CONFIG_FEATURE_TAR_GZIP=y
CONFIG_FEATURE_TAR_BZIP2=n
CONFIG_FEATURE_TAR_XZ=n

# Ed editors (nano is the primary editor)
CONFIG_VI=y
CONFIG_FEATURE_VI_COLON=y
CONFIG_FEATURE_VI_YANKMARK=y
CONFIG_FEATURE_VI_SEARCH=y
CONFIG_FEATURE_VI_USE_SIGNALS=y
CONFIG_FEATURE_VI_DOT_CMD=y
CONFIG_FEATURE_VI_READONLY=y
CONFIG_FEATURE_VI_SETOPTS=y
CONFIG_FEATURE_VI_WIN_RESIZE=y
CONFIG_FEATURE_VI_ASK_TERMINAL=y
