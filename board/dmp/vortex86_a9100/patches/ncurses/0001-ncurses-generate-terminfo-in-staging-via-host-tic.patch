From d2929e29f1f1a8b0b5c1b0b5c1b0b5c1b0b5c1b0 Mon Sep 17 00:00:00 2001
From: Vincenzo <vincenzo@users.noreply.github.com>
Date: Sat, 13 Jun 2026 10:00:00 +0000
Subject: [PATCH] ncurses: generate terminfo database in staging via host tic

During cross-compilation, the ncurses 'make install' step may not
run the terminfo compiler (tic) correctly, leaving the staging
directory without compiled terminfo entries. This causes the
NCURSES_TARGET_CLEANUP_TERMINFO hook to fail when it tries to
copy files from staging to target.

Fix by adding a staging install hook that explicitly runs the
host tic to compile the terminfo source into STAGING_DIR.

Signed-off-by: Vincenzo <vincenzo@users.noreply.github.com>
---
 package/ncurses/ncurses.mk | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/package/ncurses/ncurses.mk b/package/ncurses/ncurses.mk
index 3e6d8a1..f9b2c3d 100644
--- a/package/ncurses/ncurses.mk
+++ b/package/ncurses/ncurses.mk
@@ -135,6 +135,16 @@ NCURSES_POST_INSTALL_TARGET_HOOKS += NCURSES_TARGET_SYMLINK_RESET
 endif
 
+# Host tic may not run during cross-compile install, so generate
+# the terminfo database in staging explicitly after staging install.
+# This is needed for NCURSES_TARGET_CLEANUP_TERMINFO below.
+define NCURSES_GENERATE_TERMINFO_STAGING
+	mkdir -p $(STAGING_DIR)/usr/share/terminfo
+	$(HOST_DIR)/bin/tic -o $(STAGING_DIR)/usr/share/terminfo \
+		-x $(@D)/misc/terminfo.src
+endef
+NCURSES_POST_INSTALL_STAGING_HOOKS += NCURSES_GENERATE_TERMINFO_STAGING
+
 define NCURSES_TARGET_CLEANUP_TERMINFO
 	$(RM) -rf $(TARGET_DIR)/usr/share/terminfo $(TARGET_DIR)/usr/share/tabset
 	$(foreach t,$(NCURSES_TERMINFO_FILES), \
-- 
