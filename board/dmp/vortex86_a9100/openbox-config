<?xml version="1.0" encoding="UTF-8"?>
<!-- openbox-config for Vortex86 A9100 -->
<openbox_config xmlns="http://openbox.org/3.4/rc"
                xmlns:xi="http://www.w3.org/2001/XInclude">

  <!-- Theme -->
  <theme>
    <name>Clearlooks</name>
    <titleLayout>NLIMC</titleLayout>
    <keepBorder>yes</keepBorder>
    <animateIconify>no</animateIconify>
    <font place="ActiveWindow">
      <name>sans</name>
      <size>10</size>
      <weight>bold</weight>
      <slant>normal</slant>
    </font>
    <font place="InactiveWindow">
      <name>sans</name>
      <size>10</size>
      <weight>normal</weight>
      <slant>normal</slant>
    </font>
    <font place="MenuHeader">
      <name>sans</name>
      <size>10</size>
      <weight>bold</weight>
      <slant>normal</slant>
    </font>
    <font place="MenuItem">
      <name>sans</name>
      <size>10</size>
      <weight>normal</weight>
      <slant>normal</slant>
    </font>
    <font place="ActiveOnScreenDisplay">
      <name>sans</name>
      <size>10</size>
      <weight>bold</weight>
      <slant>normal</slant>
    </font>
    <font place="InactiveOnScreenDisplay">
      <name>sans</name>
      <size>10</size>
      <weight>bold</weight>
      <slant>normal</slant>
    </font>
  </theme>

  <!-- Margins -->
  <margins>
    <top>0</top>
    <bottom>28</bottom>
    <left>0</right>
    <right>0</right>
  </margins>

  <!-- Desktops -->
  <desktops>
    <number>2</number>
    <firstdesk>1</firstdesk>
    <names>
      <name>Main</name>
      <name>Apps</name>
    </names>
  </desktops>

  <!-- Resize -->
  <resize>
    <drawContents>no</drawContents>
    <popupShow>Never</popupShow>
    <popupPosition>Center</popupPosition>
    <popupFixedPosition>
      <x>10</x>
      <y>10</y>
    </popupFixedPosition>
  </resize>

  <!-- Mouse bindings -->
  <mouse>
    <context name="Root">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu">
          <menu>root-menu</menu>
        </action>
      </mousebind>
    </context>
    <context name="Client">
      <mousebind button="Alt+Button1" action="Press">
        <action name="Move"/>
      </mousebind>
      <mousebind button="Alt+Button3" action="Press">
        <action name="Resize"/>
      </mousebind>
    </context>
  </mouse>

  <!-- Keyboard bindings -->
  <keyboard>
    <keybind key="W-d">
      <action name="ToggleShowDesktop"/>
    </keybind>
    <keybind key="W-Tab">
      <action name="NextWindow">
        <finalactions>
          <action name="Focus"/>
          <action name="Raise"/>
          <action name="Unshade"/>
        </finalactions>
      </action>
    </keybind>
    <keybind key="A-F4">
      <action name="Close"/>
    </keybind>
    <keybind key="A-Escape">
      <action name="Lower"/>
      <action name="FocusToBottom"/>
      <action name="Unfocus"/>
    </keybind>
    <keybind key="A-Space">
      <action name="ShowMenu">
        <menu>client-menu</menu>
      </action>
    </keybind>
    <keybind key="C-A-Delete">
      <action name="Execute">
        <command>openbox --exit</command>
      </action>
    </keybind>
  </keyboard>

  <!-- Menu -->
  <menu>
    <file>menu.xml</file>
    <hideDelay>200</hideDelay>
    <middle>no</middle>
    <submenuShowDelay>100</submenuShowDelay>
    <submenuHideDelay>400</submenuHideDelay>
    <showIcons>yes</showIcons>
    <manageDesktops>yes</manageDesktops>
  </menu>

  <!-- Applications -->
  <applications>
    <application class="*">
      <focus>yes</focus>
      <desktop>all</desktop>
    </application>
    <application name="xclock">
      <decor>no</decor>
      <position>
        <x>right</x>
        <y>bottom</y>
      </position>
      <layer>below</layer>
    </application>
  </applications>

</openbox_config>
