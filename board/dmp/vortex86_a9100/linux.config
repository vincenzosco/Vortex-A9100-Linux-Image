# Linux Kernel config fragment for Vortex86 A9100 (i486, FPU-less)
# These options are merged on top of i386_defconfig
#
# IMPORTANT: This requires Linux 5.10.x LTS which still supports i486
# with FPU emulation. The kernel's built-in cmpxchg8b_emu handles atomic
# 64-bit operations that i486 CPUs lack via alternative() patching.
# DO NOT enable X86_CMPXCHG64 as the real i486 will crash on the native
# instruction.

# --- CPU / Architecture ---
CONFIG_MATH_EMULATION=y
CONFIG_M486=y
# X86_CMPXCHG64 must be DISABLED - real i486 lacks CMPXCHG8B instruction.
# Kernel 5.10 already has built-in emulation via cmpxchg8b_emu.S which
# gets compiled when CONFIG_X86_CMPXCHG64=n.
# CONFIG_X86_CMPXCHG64 is not set
CONFIG_X86_ALIGNMENT_16=y
CONFIG_X86_INTEL_USERCOPY=y
CONFIG_X86_USE_PPRO_CHECKSUM=n
CONFIG_X86_MINIMUM_CPU_FAMILY=4
CONFIG_PREEMPT=n
CONFIG_NO_HZ=y
CONFIG_HIGHMEM4G=y
CONFIG_HIGHMEM=n

# --- Bus support ---
CONFIG_ISA_BUS=y
CONFIG_ISA_DMA_API=y
CONFIG_PCI=y
CONFIG_PCI_GOANY=y
CONFIG_PCI_BIOS=n
CONFIG_PCI_DIRECT=y
CONFIG_PCI_MMCONFIG=n

# --- Storage ---
# Old IDE subsystem disabled - use libata/PATA instead (device /dev/sd*)
# CONFIG_IDE is not set
# CONFIG_IDE_GENERIC is not set
# CONFIG_BLK_DEV_IDE is not set
# CONFIG_BLK_DEV_GENERIC is not set
# CONFIG_BLK_DEV_PIIX is not set
CONFIG_ATA=y
CONFIG_ATA_SFF=y
CONFIG_PATA_LEGACY=y
CONFIG_PATA_MPIIX=y
CONFIG_PATA_PLATFORM=y
CONFIG_PATA_PCMCIA=n
CONFIG_PATA_OLDPIIX=y
CONFIG_PATA_NS87410=n
CONFIG_PATA_RDC=y
CONFIG_SATA_AHCI=n

# --- Network ---
CONFIG_NET_VENDOR_RDC=y
CONFIG_R6040=y
CONFIG_NET_VENDOR_REALTEK=y
CONFIG_8139TOO=y
CONFIG_8139CP=y
CONFIG_E1000=n
CONFIG_PCNET32=n

# --- Framebuffer / Console ---
CONFIG_FB=y
CONFIG_FB_CFB_FILLRECT=y
CONFIG_FB_CFB_COPYAREA=y
CONFIG_FB_CFB_IMAGEBLIT=y
CONFIG_FB_VESA=y
CONFIG_FB_BOOT_VESA_SUPPORT=y
CONFIG_FB_MODE_HELPERS=y
CONFIG_FB_TILEBLITTING=n
CONFIG_FB_ARC=n
CONFIG_FB_IMSTT=n
CONFIG_FB_VGA16=y
CONFIG_VGA_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y
CONFIG_FRAMEBUFFER_CONSOLE_ROTATION=n
CONFIG_LOGO=y
CONFIG_LOGO_LINUX_MONO=y
CONFIG_LOGO_LINUX_VGA16=y
CONFIG_LOGO_LINUX_CLUT224=n

# --- Input ---
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_KEYBOARD_GPIO=n
CONFIG_INPUT_MOUSE=y
CONFIG_MOUSE_PS2=y
CONFIG_MOUSE_SERIAL=n
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_MISC=n
CONFIG_SERIO=y
CONFIG_SERIO_I8042=y
CONFIG_SERIO_SERPORT=y

# --- Serial ---
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=4
CONFIG_SERIAL_8250_RUNTIME_UARTS=4
CONFIG_SERIAL_8250_EXTENDED=y
CONFIG_SERIAL_8250_MANY_PORTS=n
CONFIG_SERIAL_CORE=y
CONFIG_SERIAL_CORE_CONSOLE=y

# --- Minimal bloat removal ---
CONFIG_ACPI=n
CONFIG_EFI=n
CONFIG_APM=n
CONFIG_PNPACPI=n
CONFIG_PNPBIOS=n
CONFIG_CPU_FREQ=n
CONFIG_CPU_IDLE=n
CONFIG_PM=n
CONFIG_SUSPEND=n
CONFIG_HIBERNATION=n
CONFIG_USB_SUPPORT=n
CONFIG_SOUND=n
CONFIG_AGP=n
CONFIG_DRM=n
CONFIG_HID=n
CONFIG_MMC=n
CONFIG_RTC_CLASS=n
CONFIG_DNOTIFY=n
CONFIG_FANOTIFY=n
CONFIG_INOTIFY_USER=y
CONFIG_AUDIT=n
CONFIG_SECURITY=n
CONFIG_SECURITY_SELINUX=n
CONFIG_CRYPTO_HW=n
CONFIG_VIRTUALIZATION=n
CONFIG_NF_CONNTRACK=n
CONFIG_NETFILTER=n
CONFIG_IPV6=n
CONFIG_BRIDGE=n
CONFIG_WIRELESS=n

# --- Filesystems ---
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_EXT4_FS_XATTR=n
CONFIG_JBD2=y
CONFIG_FS_MBCACHE=y
CONFIG_VFAT_FS=y
CONFIG_FAT_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=n
CONFIG_SQUASHFS=n
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEV_TMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# --- Kernel size reduction ---
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_KALLSYMS=n
CONFIG_KALLSYMS_ALL=n
CONFIG_DEBUG_KERNEL=n
CONFIG_BUG=y
CONFIG_ELF_CORE=n
CONFIG_PRINTK=y
CONFIG_BOOT_PRINTK_DELAY=n
CONFIG_DYNAMIC_DEBUG=n
CONFIG_EARLY_PRINTK=y

# --- Boot optimizations ---
CONFIG_CMDLINE_BOOL=y
CONFIG_CMDLINE="console=ttyS0,115200n8 console=tty0 root=/dev/sda2 rootwait quiet panic=10"
CONFIG_CMDLINE_OVERRIDE=n
